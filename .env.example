# Email delivery (production)
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_FROM=Midex Website <noreply@midex-eg.com>

# Public site URL (SEO canonical, sitemap, Open Graph)
# NEXT_PUBLIC_SITE_URL=https://www.midex-eg.com

# Sanity CMS
# NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxxxxx
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_READ_TOKEN=sk...            # viewer token (draft mode / preview)
# SANITY_API_WRITE_TOKEN=sk...           # editor token (seed script only)
# SANITY_REVALIDATE_SECRET=random-string # shared secret for the revalidate webhook
